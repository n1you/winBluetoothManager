{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Win Bluetooth Manager",
  "version": "0.1.0",
  "identifier": "app.n1you.winbluetoothmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Win Bluetooth Manager",
        "width": 416,
        "height": 512,
        "minWidth": 416,
        "minHeight": 512,
        "maxWidth": 416,
        "maxHeight": 512,
        "center": true,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "shadow": true,
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
